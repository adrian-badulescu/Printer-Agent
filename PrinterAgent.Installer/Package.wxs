<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="URS Printer Agent" Manufacturer="U.R.S." Version="1.0.5.0" UpgradeCode="780b6db8-23eb-460d-9fa6-2f1d9a2d8a43" Scope="perMachine" Codepage="65001">
    <MajorUpgrade DowngradeErrorMessage="A newer version of URS Printer Agent is already installed." />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- WixUI + checkbox Exit: pornește Configuratorul (WixShellExec din Util). -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Pornește Configuratorul acum (cod înrolare și imprimante)" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT" Value="După salvare în Configurator: în Services (services.msc) reporniți «URS Printer Agent». Dacă este oprit, apăsați Start — altfel enroll nu rulează și RestaurantId rămâne necompletat în agent.json." />

    <!-- Tip 18: rulează EXE-ul deja instalat; fără WixUtil / WixShellExec. -->
    <CustomAction Id="LaunchConfigurator"
                  FileRef="ConfiguratorExeFile"
                  ExeCommand=""
                  Execute="immediate"
                  Impersonate="yes"
                  Return="asyncNoWait" />

    <UI Id="AgentInstallerUI">
      <ui:WixUI Id="WixUI_Minimal" />
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchConfigurator"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <!-- Tell WiX where to install -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="URSPrinterAgent" />
    </StandardDirectory>

    <!-- Runtime config lives here; seed on first install only (NeverOverwrite) so upgrades refresh the EXE-side template, not operator data. -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="AGENTPROGRAMDATAFOLDER" Name="URSPrinterAgent" />
    </StandardDirectory>

    <ComponentGroup Id="AgentProgramDataComponents" Directory="AGENTPROGRAMDATAFOLDER">
      <!-- Without explicit ACLs, MSI often leaves only Administrators/SYSTEM able to write; Configurator runs as normal user. -->
      <Component Id="AgentProgramDataAgentJson" Guid="e7c8d9a0-b1c2-4d5e-8f90-1a2b3c4d5e6f" Bitness="always64" NeverOverwrite="yes">
        <CreateFolder>
          <util:PermissionEx User="Users" GenericAll="yes" />
        </CreateFolder>
        <File Id="AgentProgramDataAgentJsonFile" Source="$(var.WorkerPublishDir)agent.json" KeyPath="yes">
          <util:PermissionEx User="Users" GenericAll="yes" />
        </File>
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="AgentComponents" Directory="INSTALLFOLDER">
      <!-- Publish the Worker executable -->
      <Component Id="ServiceExecutable" Guid="c4f9a1b1-2e3d-4c5b-8f7a-1b2c3d4e5f6a" Bitness="always64">
        <!-- In WiX v4, project references expose their TargetDir -->
        <File Id="AgentWorkerExe" Source="$(var.WorkerPublishDir)PrinterAgent.Worker.exe" KeyPath="yes" />
        
        <!-- Install as a Windows Service -->
        <ServiceInstall 
          Id="ServiceInstaller" 
          Type="ownProcess" 
          Name="URSPrinterAgent" 
          DisplayName="URS Printer Agent" 
          Description="Connects to the cloud backend to print restaurant orders." 
          Start="auto" 
          Account="LocalSystem" 
          ErrorControl="normal" />

        <!-- Start the service on install, Stop/Delete on uninstall -->
        <ServiceControl 
          Id="ServiceController" 
          Start="install" 
          Stop="both" 
          Remove="uninstall" 
          Name="URSPrinterAgent" 
          Wait="yes" />
      </Component>
      
      <!-- Include the configuration files -->
      <Component Id="AgentConfig" Guid="a1b2c3d4-e5f6-4a5b-8c7d-9e0f1a2b3c4d" Bitness="always64">
        <File Id="AgentJson" Source="$(var.WorkerPublishDir)agent.json" />
        <File Id="AppSettingsJson" Source="$(var.WorkerPublishDir)appsettings.json" />
      </Component>

      <Component Id="ConfiguratorExe" Guid="b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e" Bitness="always64">
        <File Id="ConfiguratorExeFile" Source="$(var.ConfiguratorPublishDir)PrinterAgent.Configurator.exe" KeyPath="yes">
          <!-- Shortcut lângă EXE (același component = per-machine; Meniul Start singur declanșează ICE cu HKLM). -->
          <Shortcut Id="ConfiguratorInstallDirShortcut"
                    Directory="INSTALLFOLDER"
                    Name="Configure URS Printer Agent"
                    WorkingDirectory="INSTALLFOLDER"
                    Advertise="no"
                    Description="Scan LAN for port 9100 and edit agent.json (EnrollmentCode, printers)." />
        </File>
      </Component>
      
    </ComponentGroup>

    <Feature Id="Main">
      <ComponentGroupRef Id="AgentComponents" />
      <ComponentGroupRef Id="AgentProgramDataComponents" />
    </Feature>
  </Package>
</Wix>
