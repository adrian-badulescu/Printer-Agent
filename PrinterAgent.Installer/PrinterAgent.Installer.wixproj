<Project Sdk="WixToolset.Sdk/4.0.0">
  <PropertyGroup>
    <OutputName>PrinterAgent</OutputName>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <InstallerPlatform>x64</InstallerPlatform>
    <!-- Pass the publish directory to Package.wxs as a preprocessor variable -->
    <WorkerPublishDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\PrinterAgent.Worker\bin\$(Configuration)\net10.0\win-x64\publish\'))</WorkerPublishDir>
    <ConfiguratorPublishDir>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)..\PrinterAgent.Configurator\bin\$(Configuration)\net10.0-windows\win-x64\publish\'))</ConfiguratorPublishDir>
    <DefineConstants>WorkerPublishDir=$(WorkerPublishDir);ConfiguratorPublishDir=$(ConfiguratorPublishDir)</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PrinterAgent.Worker\PrinterAgent.Worker.csproj" />
    <ProjectReference Include="..\PrinterAgent.Configurator\PrinterAgent.Configurator.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.6" />
    <PackageReference Include="WixToolset.Util.wixext" Version="4.0.6" />
  </ItemGroup>

  <!-- Publish worker + configurator before building the MSI (Configurator must not block MSI; runs as separate EXE after install). -->
  <Target Name="PublishAgentProjects" BeforeTargets="Build">
    <Exec Command="dotnet publish &quot;$(MSBuildThisFileDirectory)..\PrinterAgent.Worker\PrinterAgent.Worker.csproj&quot; -c $(Configuration)" />
    <Exec Command="dotnet publish &quot;$(MSBuildThisFileDirectory)..\PrinterAgent.Configurator\PrinterAgent.Configurator.csproj&quot; -c $(Configuration)" />
  </Target>

  <Target Name="SignMsi" AfterTargets="Build">
    <Exec Command="powershell -Command &quot;Set-AuthenticodeSignature -FilePath '$(TargetPath)' -Certificate (Get-ChildItem -Path Cert:\CurrentUser\My | Where-Object { $_.Subject -match 'CN=U.R.S.' } | Select-Object -First 1)&quot;" />
  </Target>
</Project>
