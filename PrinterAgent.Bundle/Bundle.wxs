<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">

  <Bundle Name="URS Printer Agent"
          Manufacturer="U.R.S."
          Version="1.0.12.0"
          UpgradeCode="d2f29b2b-8a2e-46c8-9ad5-8d29e61d2d31">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          Theme="hyperlinkLicense"
          ThemeFile="Resources\thm.xml"
          SuppressOptionsUI="yes"
          LicenseUrl="" />

      <!-- ThemeFile auto-adds thm.xml; we only add per-language localizations. -->
      <Payload Name="1033\thm.wxl" SourceFile="Resources\1033\thm.wxl" Compressed="yes" />
      <Payload Name="1040\thm.wxl" SourceFile="Resources\1040\thm.wxl" Compressed="yes" />
      <Payload Name="1036\thm.wxl" SourceFile="Resources\1036\thm.wxl" Compressed="yes" />
      <Payload Name="3082\thm.wxl" SourceFile="Resources\3082\thm.wxl" Compressed="yes" />
      <Payload Name="1031\thm.wxl" SourceFile="Resources\1031\thm.wxl" Compressed="yes" />
      <Payload Name="1053\thm.wxl" SourceFile="Resources\1053\thm.wxl" Compressed="yes" />
      <Payload Name="1048\thm.wxl" SourceFile="Resources\1048\thm.wxl" Compressed="yes" />
    </BootstrapperApplication>

    <Chain>
      <!-- WireGuard for Windows (x64) prerequisite.
           Burn will detect installed state via MSI product code and skip if already present. -->
      <MsiPackage Id="WireGuardMsi"
                  DisplayName="WireGuard"
                  DownloadUrl="https://download.wireguard.com/windows-client/wireguard-amd64-0.5.3.msi"
                  Compressed="no"
                  Cache="yes"
                  Vital="yes"
                  InstallCondition="VersionNT64">
        <!-- Prevent launching the UI after install -->
        <MsiProperty Name="DO_NOT_LAUNCH" Value="1" />
      </MsiPackage>

      <MsiPackage Id="UrsPrinterAgentMsi"
                  SourceFile="$(var.PrinterAgent.Installer.TargetPath)"
                  Compressed="yes"
                  Vital="yes" />
    </Chain>
  </Bundle>
</Wix>

