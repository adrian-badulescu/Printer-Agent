<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="URS Printer Agent"
          Manufacturer="U.R.S."
          Version="1.0.12.0"
          UpgradeCode="d2f29b2b-8a2e-46c8-9ad5-8d29e61d2d31">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          Theme="hyperlinkLicense"
          ThemeFile="Resources\thm.xml"
          SuppressOptionsUI="yes"
          LaunchTarget="[ProgramFiles64Folder]URSPrinterAgent\PrinterAgent.Configurator.exe"
          LaunchWorkingFolder="[ProgramFiles64Folder]URSPrinterAgent"
          LicenseUrl="" />

      <!-- ThemeFile auto-adds thm.xml; we only add per-language localizations. -->
      <Payload Name="1033\thm.wxl" SourceFile="Resources\1033\thm.wxl" Compressed="yes" />
      <Payload Name="1040\thm.wxl" SourceFile="Resources\1040\thm.wxl" Compressed="yes" />
      <Payload Name="1036\thm.wxl" SourceFile="Resources\1036\thm.wxl" Compressed="yes" />
      <Payload Name="3082\thm.wxl" SourceFile="Resources\3082\thm.wxl" Compressed="yes" />
      <Payload Name="1031\thm.wxl" SourceFile="Resources\1031\thm.wxl" Compressed="yes" />
      <Payload Name="1053\thm.wxl" SourceFile="Resources\1053\thm.wxl" Compressed="yes" />
      <Payload Name="1048\thm.wxl" SourceFile="Resources\1048\thm.wxl" Compressed="yes" />
    </BootstrapperApplication>

    <!-- Detect presence of WireGuard by checking for wireguard.exe in the default install location. -->
    <util:FileSearch Id="WireGuardExeExistsSearch"
                     Variable="WireGuardExeExists"
                     Path="[ProgramFiles64Folder]WireGuard\wireguard.exe"
                     Result="exists" />

    <Chain>
      <!-- WireGuard for Windows (x64) prerequisite.
           Payload is embedded from redist\wireguard-installer.exe (downloaded at bundle build time).
           Runtime-only DownloadUrl without Hash/Size is unreliable in WiX Burn v4; embedding avoids silent skip. -->
      <ExePackage Id="WireGuardInstallerExe"
                  DisplayName="WireGuard"
                  InstallArguments="/noprompt"
                  DetectCondition="WireGuardExeExists"
                  Cache="keep"
                  Vital="yes"
                  Permanent="yes"
                  InstallCondition="VersionNT64">
        <ExePackagePayload Name="wireguard-installer.exe"
                           SourceFile="redist\wireguard-installer.exe"
                           Compressed="yes" />
      </ExePackage>

      <!-- Printer Agent MSI: WiX builds per-culture output under bin\<cfg>\<culture>\PrinterAgent.msi. -->
      <!-- Unique Name paths avoid duplicate PrinterAgent.msi / cab*.cab in the attached container (WIX8500),
           which otherwise overwrites payloads at extract time and triggers MSI "browse for source". -->
      <MsiPackage Id="UrsPrinterAgentMsi_it"
                  Name="it-IT\PrinterAgent.msi"
                  SourceFile="$(var.PrinterAgent.Installer.TargetDir)it-IT\PrinterAgent.msi"
                  Compressed="yes"
                  Vital="yes"
                  InstallCondition="WixBundleCulture = &quot;it-IT&quot;" />

      <MsiPackage Id="UrsPrinterAgentMsi_en"
                  Name="en-US\PrinterAgent.msi"
                  SourceFile="$(var.PrinterAgent.Installer.TargetDir)en-US\PrinterAgent.msi"
                  Compressed="yes"
                  Vital="yes"
                  InstallCondition="WixBundleCulture &lt;&gt; &quot;it-IT&quot;" />
    </Chain>
  </Bundle>
</Wix>

