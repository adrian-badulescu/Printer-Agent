<Project Sdk="WixToolset.Sdk/4.0.0">
  <PropertyGroup>
    <OutputName>URSPrinterAgentSetup</OutputName>
    <OutputType>Bundle</OutputType>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- Do not treat our runtime thm.wxl payloads as compile-time localization inputs. -->
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <DefineConstants>$(DefineConstants)</DefineConstants>
    <WireGuardInstallerUrl>https://download.wireguard.com/windows-client/wireguard-installer.exe</WireGuardInstallerUrl>
    <WireGuardRedistExe>$(MSBuildThisFileDirectory)redist\wireguard-installer.exe</WireGuardRedistExe>
  </PropertyGroup>

  <!-- Embed WireGuard fetcher in the bundle EXE. WiX Burn remote DownloadUrl without Hash/Size often does not run at install time. -->
  <Target Name="EnsureWireGuardRedist" BeforeTargets="BeforeBuild">
    <MakeDir Directories="$(MSBuildThisFileDirectory)redist" />
    <Exec Condition="!Exists('$(WireGuardRedistExe)')"
          IgnoreExitCode="false"
          ConsoleToMsBuild="true"
          WorkingDirectory="$(MSBuildThisFileDirectory)"
          Command="powershell -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command &quot;$ProgressPreference = 'SilentlyContinue'; [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -Uri '$(WireGuardInstallerUrl)' -OutFile '$(WireGuardRedistExe)' -UseBasicParsing&quot;" />
    <Error Condition="!Exists('$(WireGuardRedistExe)')"
           Text="Missing $(WireGuardRedistExe). Build once with network access, or download wireguard-installer.exe manually into PrinterAgent.Bundle\redist\" />
  </Target>

  <ItemGroup>
    <!-- Ensure MSI gets built before bundle. -->
    <ProjectReference Include="..\PrinterAgent.Installer\PrinterAgent.Installer.wixproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.Bal.wixext" Version="4.0.6" />
    <PackageReference Include="WixToolset.Util.wixext" Version="4.0.6" />
  </ItemGroup>

  <!-- Theme localization is resolved at runtime from payloads (1033\thm.wxl etc.). -->

  <!-- Same cert/modes as MSI: -p:SelfSignedMsiSigning=true or -p:SkipMsiSigning=true to skip. -->
  <Target Name="SignBundleExe" AfterTargets="Build" Condition="'$(SkipMsiSigning)' != 'true'">
    <PropertyGroup>
      <_BundleSignMode Condition="'$(SelfSignedMsiSigning)' == 'true'">SelfSigned</_BundleSignMode>
      <_BundleSignMode Condition="'$(_BundleSignMode)' == ''">Enterprise</_BundleSignMode>
    </PropertyGroup>
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)..\PrinterAgent.Installer\SignAuthenticode.ps1&quot; -Path &quot;$(TargetPath)&quot; -Mode $(_BundleSignMode)" />
  </Target>
</Project>
